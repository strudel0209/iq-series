      "scope": "[format('Microsoft.CognitiveServices/accounts/{0}', variables('names').openAi)]",
      "name": "[guid(resourceGroup().id, variables('names').openAi, 'seed', variables('roles').cognitiveServicesUser)]",
      "properties": {
        "principalId": "[if(parameters('seedData'), reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-{1}', parameters('resourcePrefix'), variables('uniqueSuffix'))), '2023-01-31').principalId, '')]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roles').cognitiveServicesUser)]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('names').openAi)]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-{1}', parameters('resourcePrefix'), variables('uniqueSuffix')))]"
      ]
    },
    {
      "condition": "[parameters('seedData')]",
      "type": "Microsoft.Resources/deploymentScripts",
      "apiVersion": "2023-08-01",
      "name": "[format('{0}-seed-data', parameters('resourcePrefix'))]",
      "location": "[parameters('location')]",
      "kind": "AzureCLI",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-{1}', parameters('resourcePrefix'), variables('uniqueSuffix'))))]": {}
        }
      },
      "properties": {
        "azCliVersion": "2.61.0",
        "retentionInterval": "PT1H",
        "cleanupPreference": "OnSuccess",
        "timeout": "PT15M",
        "forceUpdateTag": "[variables('uniqueSuffix')]",
        "scriptContent": "[variables('$fxv#0')]",
        "environmentVariables": [
          {
            "name": "SEARCH_ENDPOINT",
            "value": "[format('https://{0}.search.windows.net', variables('names').search)]"
          },
          {
            "name": "AOAI_ENDPOINT",
            "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('names').openAi), '2023-10-01-preview').endpoint]"
          },
          {
            "name": "EMBEDDING_MODEL",
            "value": "[parameters('embeddingModelName')]"
          },
          {
            "name": "EMBEDDING_DEPLOYMENT",
            "value": "[variables('names').embeddingDeployment]"
          },
          {
            "name": "GPT_MODEL",
            "value": "[parameters('chatModelName')]"
          },
          {
            "name": "GPT_DEPLOYMENT",
            "value": "[variables('names').chatDeployment]"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('names').openAi, variables('names').chatDeployment)]",
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('names').openAi, variables('names').embeddingDeployment)]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('names').openAi)]",
        "[resourceId('Microsoft.Search/searchServices', variables('names').search)]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-seed-{1}', parameters('resourcePrefix'), variables('uniqueSuffix')))]",
        "[extensionResourceId(resourceId('Microsoft.CognitiveServices/accounts', variables('names').openAi), 'Microsoft.Authorization/roleAssignments', guid(resourceGroup().id, variables('names').openAi, 'seed', variables('roles').cognitiveServicesUser))]",
        "[extensionResourceId(resourceId('Microsoft.Search/searchServices', variables('names').search), 'Microsoft.Authorization/roleAssignments', guid(resourceGroup().id, variables('names').search, 'seed', variables('roles').searchServiceContributor))]",
        "[extensionResourceId(resourceId('Microsoft.Search/searchServices', variables('names').search), 'Microsoft.Authorization/roleAssignments', guid(resourceGroup().id, variables('names').search, 'seed', variables('roles').searchIndexDataContributor))]"
      ]
    }
  ],
  "outputs": {
    "searchEndpoint": {
      "type": "string",
      "metadata": {
        "description": "AI Search endpoint"
      },
      "value": "[format('https://{0}.search.windows.net', variables('names').search)]"
    },
    "searchApiKey": {
      "type": "string",
      "metadata": {
        "description": "AI Search admin API key"
      },
      "value": "[listAdminKeys(resourceId('Microsoft.Search/searchServices', variables('names').search), '2023-11-01').primaryKey]"
    },
    "openAiEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Azure OpenAI endpoint"
      },
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('names').openAi), '2023-10-01-preview').endpoint]"
    },
    "aiServicesEndpoint": {
      "type": "string",
      "metadata": {
        "description": "AI Services endpoint"
      },
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('names').aiServices), '2025-06-01').endpoint]"
    },
    "aiServicesName": {
      "type": "string",
      "metadata": {
        "description": "AI Services name"
      },
      "value": "[variables('names').aiServices]"
    },
    "embeddingDeploymentName": {
      "type": "string",
      "metadata": {
        "description": "Embedding deployment name"
      },
      "value": "[variables('names').embeddingDeployment]"
    },
    "chatDeploymentName": {
      "type": "string",
      "metadata": {
        "description": "Chat deployment name"
      },
      "value": "[variables('names').chatDeployment]"
    },
    "searchServiceName": {
      "type": "string",
      "metadata": {
        "description": "Search service name"
      },
      "value": "[variables('names').search]"
    },
    "openAiServiceName": {
      "type": "string",
      "metadata": {
        "description": "OpenAI service name"
      },
      "value": "[variables('names').openAi]"
    },
    "foundryProjectEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Foundry project endpoint"
      },
      "value": "[format('https://{0}.services.ai.azure.com/api/projects/{1}', variables('names').aiServices, variables('names').project)]"
    },
    "searchConnectionName": {
      "type": "string",
      "metadata": {
        "description": "AI Search connection name (use in .env)"
      },
      "value": "[variables('names').searchConnection]"
    },
    "blobConnectionString": {
      "type": "string",
      "metadata": {
        "description": "Blob Storage connection string (use as BLOB_CONNECTION_STRING in .env)"
      },
      "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix={2}', variables('names').storage, listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('names').storage), '2023-05-01').keys[0].value, environment().suffixes.storage)]"
    },
    "blobContainerName": {
      "type": "string",
      "metadata": {
        "description": "Blob container name (use as BLOB_CONTAINER_NAME in .env)"
      },
      "value": "[variables('names').blobContainer]"
    },
    "resourceLocation": {
      "type": "string",
      "metadata": {
        "description": "Resource location"
      },
      "value": "[parameters('location')]"
    },
    "knowledgeBaseName": {
      "type": "string",
      "metadata": {
        "description": "Knowledge base name (for MCP endpoint)"
      },
      "value": "earth-knowledge-base"
    },
    "mcpEndpoint": {
      "type": "string",
      "metadata": {
        "description": "MCP endpoint URL (connect agents to the knowledge base)"
      },
      "value": "[format('https://{0}.search.windows.net/knowledgebases/earth-knowledge-base/mcp', variables('names').search)]"
    }
  }
}